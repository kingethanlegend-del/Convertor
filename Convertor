def cups_to_grams(cups,ingredient) :
    conversion_rates = {
        "flour":120,
        "sugar":200,
        "butter":230
    }
    if ingredient in conversion_rates:
        grams = cups*conversion_rates[ingredient]
        return grams
    else:
        return "conversion rate for this ingredient is not available."

